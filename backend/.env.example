# App
DEBUG=false
DATA_DIR=./data
STATE_FILE=state.json

# Database (PostgreSQL)
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/legal_content_os

# LLM (OpenAI-compatible — works with Groq, OpenAI, Azure, etc.)
# Groq (free): get key at https://console.groq.com/keys
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.3-70b-versatile

# To use OpenAI instead, comment out the above and use:
# OPENAI_API_KEY=sk-your-openai-key
# OPENAI_BASE_URL=
# LLM_MODEL=gpt-4o

# Tavily (optional — SCC / web search)
TAVILY_API_KEY=

# RSS (override if feed URLs change)
RSS_LIVELAW=https://www.livelaw.in/rss
RSS_BARANDBENCH=https://www.barandbench.com/feed
RSS_INDIALEGAL=https://indialegallive.com/feed/
RSS_SUPREME_COURT=https://main.sci.gov.in/rss/latest-feed
RSS_HIGH_COURTS=https://www.indiankanoon.org/rss/  # Example - would need specific court feeds

# Scheduler
INGEST_CRON_MINUTES=30
PUBLISH_SCAN_INTERVAL_SECONDS=60

# LinkedIn (Posts / UGC)
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_PERSON_URN=
LINKEDIN_ORGANIZATION_ID=

# X (Twitter) OAuth 1.0a
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=

# Reddit (script app + password grant)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=legal-content-os/0.1
REDDIT_USERNAME=
REDDIT_PASSWORD=
REDDIT_SUBREDDIT=test

# Framer CMS (verify exact API path in Framer docs for your workspace)
FRAMER_API_TOKEN=
FRAMER_PROJECT_ID=
FRAMER_COLLECTION_ID=

# Medium Integration API
MEDIUM_INTEGRATION_TOKEN=
MEDIUM_PUBLICATION_ID=
